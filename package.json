{
  "name": "sculp-js",
  "version": "1.19.1",
  "description": "Utils function library for modern javascript",
  "scripts": {
    "prepare": "husky install",
    "build": "rollup  --bundleConfigAsCjs --config rollup.config.js",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist/types src/index.ts",
    "build:core": "BUILD_TARGET=core rollup  --bundleConfigAsCjs --config rollup.config.js",
    "build:terser": "node scripts/build.js",
    "test:unit": "jest",
    "test": "jest --coverage",
    "coveralls": "jest --coverage --coverageReporters=text-lcov | coveralls",
    "lint": "eslint ./src --ext .vue,.js,jsx,.ts,tsx",
    "lint:fix": "eslint --fix ./src --ext .vue,.js,jsx,.ts,tsx",
    "prettier": "prettier -c --write \"**/*.{vue,ts,js,jsx,css,less,scss,json}\"",
    "docs:gen-api": "node scripts/gen-docs-site-api.js",
    "docs:sync": "node scripts/sync-docs-site-api.mjs",
    "docs:dev": "node scripts/docs-dev.mjs",
    "docs:build": "node scripts/docs-build.mjs",
    "docs:preview": "node scripts/docs-preview.js",
    "docs:deploy": "npm run docs:gen-api && npm run docs:sync && npm run docs:build"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "browser": "./dist/umd/index.min.js",
  "unpkg": "./dist/umd/index.min.js",
  "jsdelivr": "./dist/umd/index.min.js",
  "typesVersions": {
    "*": {
      "./array": [
        "./dist/types/array.d.ts"
      ],
      "./async": [
        "./dist/types/async.d.ts"
      ],
      "./base64": [
        "./dist/types/base64.d.ts"
      ],
      "./clipboard": [
        "./dist/types/clipboard.d.ts"
      ],
      "./cloneDeep": [
        "./dist/types/cloneDeep.d.ts"
      ],
      "./cookie": [
        "./dist/types/cookie.d.ts"
      ],
      "./date": [
        "./dist/types/date.d.ts"
      ],
      "./dom": [
        "./dist/types/dom.d.ts"
      ],
      "./download": [
        "./dist/types/download.d.ts"
      ],
      "./file": [
        "./dist/types/file.d.ts"
      ],
      "./func": [
        "./dist/types/func.d.ts"
      ],
      "./isEqual": [
        "./dist/types/isEqual.d.ts"
      ],
      "./math": [
        "./dist/types/math.d.ts"
      ],
      "./number": [
        "./dist/types/number.d.ts"
      ],
      "./object": [
        "./dist/types/object.d.ts"
      ],
      "./path": [
        "./dist/types/path.d.ts"
      ],
      "./qs": [
        "./dist/types/qs.d.ts"
      ],
      "./random": [
        "./dist/types/random.d.ts"
      ],
      "./string": [
        "./dist/types/string.d.ts"
      ],
      "./tooltip": [
        "./dist/types/tooltip.d.ts"
      ],
      "./tree": [
        "./dist/types/tree.d.ts"
      ],
      "./type": [
        "./dist/types/type.d.ts"
      ],
      "./unique": [
        "./dist/types/unique.d.ts"
      ],
      "./url": [
        "./dist/types/url.d.ts"
      ],
      "./unicodeToolkit": [
        "./dist/types/unicodeToolkit.d.ts"
